#!/bin/sh

while read local_ref local_sha remote_ref remote_sha
do
  if [ "$remote_ref" = "refs/heads/main" ] && [ "$JESSE_APPROVED_MAIN_PUSH" != "1" ]; then
    cat >&2 <<'EOF'
Blocked push to main.

Workflow:
1. Queue changes on a feature branch.
2. Let Jesse test.
3. Wait for Jesse's explicit go-ahead.
4. Merge the feature branch to main.
5. Push main with JESSE_APPROVED_MAIN_PUSH=1.
EOF
    exit 1
  fi
done

exit 0
